# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
WORKSH_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
WORKS2_OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_WORKSHOP_API_KEY=your_gemini_api_key_here

# Database (MySQL/TiDB or SQLite)
DATABASE_URL=mysql://user:password@host:port/dbname
# Or for development: DATABASE_URL=sqlite:./app.db

# Server
PORT=3001
NODE_ENV=development

# Client
VITE_API_URL=http://localhost:3001
